#!/bin/bash
# ─────────────────────────────────────────────────────
#  pre-commit hook: 每次提交前检查版本号和 CHANGELOG
# ─────────────────────────────────────────────────────
# 安装: git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────

echo ""
echo "🔍 [pre-commit] 检查版本号和 CHANGELOG..."

# 1. 检测本次是否有 Kotlin/XML/Gradle/PNG 等代码变更
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(kt|java|xml|kts|gradle|pro|png)$' || true)

if [ -z "$STAGED" ]; then
    echo "✅ [pre-commit] 无代码变更，跳过版本检查"
    exit 0
fi

# 2. 检查 CHANGELOG.md 是否被 staging
CHANGELOG_STAGED=$(git diff --cached --name-only | grep -c "CHANGELOG.md" || true)
if [ "$CHANGELOG_STAGED" -eq 0 ]; then
    echo "❌ [pre-commit] 检测到代码变更，但 CHANGELOG.md 未更新！"
    echo "   → 请在提交前更新 CHANGELOG.md"
    echo ""
    echo "  修改提示（添加到 CHANGELOG.md 顶部）："
    echo "  ## [x.y.z] — $(date "+%Y-%m-%d %H:%M")"
    echo ""
    echo "  如果确实不需要更新 CHANGELOG，请强制提交: git commit --no-verify"
    exit 1
fi

# 3. 检查 build.gradle.kts 的版本号是否变更（versionCode/versionName）
BUILD_GRADLE_STAGED=$(git diff --cached --name-only | grep -c "build.gradle.kts" || true)
if [ "$BUILD_GRADLE_STAGED" -eq 0 ]; then
    echo "⚠️  [pre-commit] 提示: build.gradle.kts 未 staging，版本号可能未更新"
    echo "   → 如果需要更新版本号，请执行: npm run bump"
fi

echo "✅ [pre-commit] 检查通过"
exit 0
